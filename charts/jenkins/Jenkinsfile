pipeline {
    agent any

    environment {
        DOCKERHUB_CREDENTIALS = credentials('dockerhub')
        DOCKERHUB_USER        = 'nithishpavan-nk'
        IMAGE_BACKEND         = "${DOCKERHUB_USER}/novashop-backend"
        IMAGE_FRONTEND        = "${DOCKERHUB_USER}/novashop-frontend"
        IMAGE_TAG             = "${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Verify Docker') {
            steps {
                sh 'docker --version && docker compose version'
            }
        }

        stage('Build Images') {
            parallel {
                stage('Backend') {
                    steps {
                        sh 'docker build -t ${IMAGE_BACKEND}:${IMAGE_TAG} -t ${IMAGE_BACKEND}:latest charts/docker/ecommerce-backend'
                    }
                }
                stage('Frontend') {
                    steps {
                        sh 'docker build -t ${IMAGE_FRONTEND}:${IMAGE_TAG} -t ${IMAGE_FRONTEND}:latest charts/docker/ecommerce-frontend'
                    }
                }
            }
        }

        stage('Push to Docker Hub') {
            steps {
                sh '''
                    echo $DOCKERHUB_CREDENTIALS_PSW | docker login -u $DOCKERHUB_USER --password-stdin
                    docker push ${IMAGE_BACKEND}:${IMAGE_TAG}
                    docker push ${IMAGE_BACKEND}:latest
                    docker push ${IMAGE_FRONTEND}:${IMAGE_TAG}
                    docker push ${IMAGE_FRONTEND}:latest
                '''
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                    docker compose -p novashop down || true
                    docker compose -p novashop up -d --pull always
                '''
            }
        }

        stage('Health Check') {
            steps {
                sh '''
                    for i in $(seq 1 15); do
                        if curl -sf http://localhost:5000/ > /dev/null; then
                            echo "✅ Backend healthy!"
                            exit 0
                        fi
                        echo "Waiting... attempt $i/15"
                        sleep 5
                    done
                    echo "❌ Health check failed"
                    exit 1
                '''
            }
        }
    }

    post {
        success {
            sh 'docker image prune -f'
            echo '🎉 NovaShop deployed successfully!'
        }
        failure {
            echo '❌ Deployment failed — check the console output above.'
        }
        always {
            sh 'docker ps -a'
        }
    }
}
